<Window x:Class="GROUP04WPF.Views.CustomerMainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Customer Dashboard" Height="400" Width="600">
    <Grid>
        <StackPanel Margin="20">
            <TextBlock Text="{Binding Customer.CustomerFullName}" FontSize="16" FontWeight="Bold" />
            <Button Content="View Profile" Command="{Binding ProfileCommand}" Margin="0,5" />
            <Button Content="Booking History" Command="{Binding BookingHistoryCommand}" Margin="0,5" />
            <Button Content="Logout" Command="{Binding LogoutCommand}" Margin="0,5" />
        </StackPanel>
    </Grid>
</Window>