<Window x:Class="GROUP04WPF.Views.ProfileView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Profile" Height="400" Width="400">
    <Grid>
        <StackPanel Margin="20">
            <TextBlock Text="Full Name:" />
            <TextBox Text="{Binding Customer.CustomerFullName, UpdateSourceTrigger=PropertyChanged}" />
            <TextBlock Text="Telephone:" Margin="0,10,0,0" />
            <TextBox Text="{Binding Customer.Telephone, UpdateSourceTrigger=PropertyChanged}" />
            <TextBlock Text="Email:" Margin="0,10,0,0" />
            <TextBox Text="{Binding Customer.EmailAddress, UpdateSourceTrigger=PropertyChanged}" />
            <TextBlock Text="Birthday:" Margin="0,10,0,0" />
            <TextBox Text="{Binding Customer.CustomerBirthday, StringFormat=yyyy-MM-dd, UpdateSourceTrigger=PropertyChanged}" />
            <TextBlock Text="Password:" Margin="0,10,0,0" />
            <TextBox Text="{Binding Customer.Password, UpdateSourceTrigger=PropertyChanged}" />
            <Button Content="Update" Command="{Binding UpdateCommand}" Margin="0,20,0,0" />
        </StackPanel>
    </Grid>
</Window>