<Window x:Class="GROUP04WPF.Views.RoomDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Room Details" Height="400" Width="400">
    <Grid>
        <StackPanel Margin="20">
            <TextBlock Text="Room Number:" />
            <TextBox Text="{Binding RoomNumber, UpdateSourceTrigger=PropertyChanged}" />
            <TextBlock Text="Description:" Margin="0,10,0,0" />
            <TextBox Text="{Binding RoomDetailDescription, UpdateSourceTrigger=PropertyChanged}" />
            <TextBlock Text="Max Capacity:" Margin="0,10,0,0" />
            <TextBox Text="{Binding RoomMaxCapacity, UpdateSourceTrigger=PropertyChanged}" />
            <TextBlock Text="Room Type ID:" Margin="0,10,0,0" />
            <TextBox Text="{Binding RoomTypeID, UpdateSourceTrigger=PropertyChanged}" />
            <TextBlock Text="Status:" Margin="0,10,0,0" />
            <TextBox Text="{Binding RoomStatus, UpdateSourceTrigger=PropertyChanged}" />
            <TextBlock Text="Price Per Day:" Margin="0,10,0,0" />
            <TextBox Text="{Binding RoomPricePerDay, UpdateSourceTrigger=PropertyChanged}" />
            <StackPanel Orientation="Horizontal" Margin="0,20,0,0">
                <Button Content="Save" Click="Save_Click" Margin="0,0,10,0" />
                <Button Content="Cancel" Click="Cancel_Click" />
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>