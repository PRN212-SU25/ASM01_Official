<Window x:Class="GROUP04WPF.Views.CustomerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Customer Details" Height="400" Width="400">
    <Grid>
        <StackPanel Margin="20">
            <TextBlock Text="Full Name:" />
            <TextBox Text="{Binding CustomerFullName, UpdateSourceTrigger=PropertyChanged}" />
            <TextBlock Text="Telephone:" Margin="0,10,0,0" />
            <TextBox Text="{Binding Telephone, UpdateSourceTrigger=PropertyChanged}" />
            <TextBlock Text="Email:" Margin="0,10,0,0" />
            <TextBox Text="{Binding EmailAddress, UpdateSourceTrigger=PropertyChanged}" />
            <TextBlock Text="Birthday:" Margin="0,10,0,0" />
            <TextBox Text="{Binding CustomerBirthday, StringFormat=yyyy-MM-dd, UpdateSourceTrigger=PropertyChanged}" />
            <TextBlock Text="Status:" Margin="0,10,0,0" />
            <TextBox Text="{Binding CustomerStatus, UpdateSourceTrigger=PropertyChanged}" />
            <TextBlock Text="Password:" Margin="0,10,0,0" />
            <TextBox Text="{Binding Password, UpdateSourceTrigger=PropertyChanged}" />
            <StackPanel Orientation="Horizontal" Margin="0,20,0,0">
                <Button Content="Save" Click="Save_Click" Margin="0,0,10,0" />
                <Button Content="Cancel" Click="Cancel_Click" />
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>