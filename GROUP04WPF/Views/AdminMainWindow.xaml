<Window x:Class="GROUP04WPF.Views.AdminMainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Admin Dashboard" Height="400" Width="600">
    <Grid>
        <StackPanel Margin="20">
            <Button Content="Customer Management" Command="{Binding CustomerManagementCommand}" Margin="0,5" />
            <Button Content="Room Management" Command="{Binding RoomManagementCommand}" Margin="0,5" />
            <Button Content="Generate Report" Command="{Binding ReportCommand}" Margin="0,5" />
            <Button Content="Logout" Command="{Binding LogoutCommand}" Margin="0,5" />
        </StackPanel>
    </Grid>
</Window>