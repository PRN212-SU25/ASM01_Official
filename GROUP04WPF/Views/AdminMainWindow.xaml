<Window x:Class="GROUP04WPF.Views.AdminMainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Admin Dashboard" Height="400" Width="600"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <StackPanel Margin="20">
            <Button Content="Customer Management" Command="{Binding CustomerManagementCommand}" Margin="100,40,100,10" Height="50" />
            <Button Content="Room Management" Command="{Binding RoomManagementCommand}" Margin="100,5,100,10" Height="50"/>
            <Button Content="Generate Report" Command="{Binding ReportCommand}" Margin="100,5,100,10" Height="50"/>
            <Button Content="Logout" Command="{Binding LogoutCommand}" Margin="100,5" Height="50"/>
        </StackPanel>
    </Grid>
</Window>